@page
@model IndustrialApp.Api.Pages.AiAssistant.IndexModel

@{
ViewData["Title"] = "Industrial AI Assistant";
}

<section class="ai-page-shell">
    <div class="ai-background-glow ai-background-glow-one"></div>
    <div class="ai-background-glow ai-background-glow-two"></div>

    <div class="ai-layout">
        <aside class="ai-hero-card">
            <div class="ai-brand-row">
                <div class="ai-brand-mark">AI</div>
                <div>
                    <div class="ai-eyebrow">Industrial Intelligence</div>
                    <h1>AI Assistant</h1>
                </div>
            </div>

            <p class="ai-hero-text">
                Ask production, quality, document, process, and log-related questions in one focused workspace.
            </p>

            <div class="ai-feature-grid">
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">◆</span>
                    <strong>Production Support</strong>
                    <span>Analyze shopfloor and process questions.</span>
                </div>
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">●</span>
                    <strong>Document Insight</strong>
                    <span>Summarize instructions and technical context.</span>
                </div>
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">▲</span>
                    <strong>Quality Focus</strong>
                    <span>Reason about defects, logs, and findings.</span>
                </div>
            </div>
        </aside>

        <main class="ai-chat-panel">
            <div class="ai-panel-header">
                <div>
                    <div class="ai-status-row">
                        <span class="ai-status-dot"></span>
                        <span>Local AI ready</span>
                    </div>
                    <h2>Ask a question</h2>
                </div>
                <div class="ai-model-badge">Ollama</div>
            </div>

            <form method="post" asp-page="/AiAssistant/Index" id="aiForm" class="ai-form">
                @Html.AntiForgeryToken()

                <label for="Question" class="ai-label">Your question</label>

                <div class="ai-input-shell">
                    <textarea name="Question"
                              id="Question"
                              class="ai-textarea"
                              rows="8"
                              placeholder="Ask something about production, documents, logs, quality issues...">@Model.Question</textarea>
                </div>

                <div class="ai-actions">
                    <div class="ai-hint">
                        Tip: include part numbers, machine names, log excerpts, or document references for better answers.
                    </div>
                    <button type="submit" class="ai-submit-button" id="askButton">
                        <span class="ai-button-text">Ask AI</span>
                        <span class="ai-button-loader" aria-hidden="true"></span>
                    </button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
            <div class="ai-alert ai-alert-error" role="alert">
                <div class="ai-alert-icon">!</div>
                <div>
                    <strong>Request failed</strong>
                    <p>@Model.ErrorMessage</p>
                </div>
            </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Answer))
            {
            <section class="ai-answer-card">
                <div class="ai-answer-header">
                    <div>
                        <span class="ai-answer-kicker">AI response</span>
                        <h3>Answer</h3>
                    </div>
                    <button type="button" class="ai-copy-button" id="copyAnswerButton">Copy</button>
                </div>

                <pre class="ai-answer" id="aiAnswer">@Model.Answer</pre>
            </section>
            }
        </main>
    </div>
</section>

<script>
    const form = document.getElementById("aiForm");
    const button = document.getElementById("askButton");
    const copyButton = document.getElementById("copyAnswerButton");
    const answer = document.getElementById("aiAnswer");

    if (form && button) {
        form.addEventListener("submit", () => {
            button.disabled = true;
            button.classList.add("is-loading");
            button.querySelector(".ai-button-text").innerText = "Thinking...";
        });
    }

    if (copyButton && answer) {
        copyButton.addEventListener("click", async () => {
            await navigator.clipboard.writeText(answer.innerText);
            copyButton.innerText = "Copied";
            setTimeout(() => copyButton.innerText = "Copy", 1600);
        });
    }
</script>

<style>
    :root {
        --ai-bg: #0f172a;
        --ai-surface: rgba(15, 23, 42, 0.82);
        --ai-surface-strong: rgba(30, 41, 59, 0.92);
        --ai-card: rgba(255, 255, 255, 0.08);
        --ai-card-border: rgba(255, 255, 255, 0.14);
        --ai-text: #e5e7eb;
        --ai-muted: #94a3b8;
        --ai-soft: #cbd5e1;
        --ai-accent: #38bdf8;
        --ai-accent-strong: #0ea5e9;
        --ai-danger: #fb7185;
        --ai-success: #22c55e;
        --ai-shadow: 0 28px 80px rgba(2, 6, 23, 0.55);
    }

    body {
        background: var(--ai-bg);
    }

    .ai-page-shell {
        position: relative;
        min-height: calc(100vh - 32px);
        overflow: hidden;
        padding: 48px 24px;
        color: var(--ai-text);
        background:
            radial-gradient(circle at top left, rgba(56, 189, 248, 0.18), transparent 34%),
            radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.16), transparent 32%),
            linear-gradient(135deg, #020617 0%, #0f172a 48%, #111827 100%);
    }

    .ai-background-glow {
        position: absolute;
        width: 420px;
        height: 420px;
        border-radius: 999px;
        filter: blur(70px);
        opacity: 0.35;
        pointer-events: none;
    }

    .ai-background-glow-one {
        top: -120px;
        right: 12%;
        background: #38bdf8;
    }

    .ai-background-glow-two {
        bottom: -160px;
        left: 8%;
        background: #6366f1;
    }

    .ai-layout {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(280px, 0.9fr) minmax(420px, 1.4fr);
        gap: 28px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .ai-hero-card,
    .ai-chat-panel {
        border: 1px solid var(--ai-card-border);
        border-radius: 28px;
        background: var(--ai-surface);
        box-shadow: var(--ai-shadow);
        backdrop-filter: blur(22px);
    }

    .ai-hero-card {
        padding: 34px;
    }

    .ai-brand-row {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 32px;
    }

    .ai-brand-mark {
        display: grid;
        place-items: center;
        width: 58px;
        height: 58px;
        border-radius: 18px;
        color: #020617;
        font-weight: 900;
        letter-spacing: -0.04em;
        background: linear-gradient(135deg, #e0f2fe, #38bdf8 55%, #0284c7);
        box-shadow: 0 18px 45px rgba(56, 189, 248, 0.35);
    }

    .ai-eyebrow,
    .ai-answer-kicker {
        color: var(--ai-accent);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    h1,
    h2,
    h3,
    p {
        margin: 0;
    }

    h1 {
        margin-top: 4px;
        font-size: clamp(2rem, 4vw, 3.4rem);
        line-height: 0.95;
        letter-spacing: -0.07em;
    }

    h2 {
        margin-top: 8px;
        font-size: clamp(1.7rem, 2.6vw, 2.4rem);
        letter-spacing: -0.05em;
    }

    h3 {
        margin-top: 4px;
        font-size: 1.25rem;
        letter-spacing: -0.03em;
    }

    .ai-hero-text {
        max-width: 560px;
        color: var(--ai-soft);
        font-size: 1.05rem;
        line-height: 1.75;
    }

    .ai-feature-grid {
        display: grid;
        gap: 14px;
        margin-top: 34px;
    }

    .ai-feature-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 4px 14px;
        padding: 18px;
        border: 1px solid var(--ai-card-border);
        border-radius: 20px;
        background: var(--ai-card);
    }

    .ai-feature-icon {
        grid-row: span 2;
        color: var(--ai-accent);
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .ai-feature-card strong {
        color: #f8fafc;
    }

    .ai-feature-card span:last-child {
        color: var(--ai-muted);
        font-size: 0.93rem;
    }

    .ai-chat-panel {
        padding: 30px;
    }

    .ai-panel-header,
    .ai-answer-header,
    .ai-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
    }

    .ai-status-row {
        display: flex;
        align-items: center;
        gap: 9px;
        color: var(--ai-muted);
        font-size: 0.92rem;
    }

    .ai-status-dot {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--ai-success);
        box-shadow: 0 0 0 7px rgba(34, 197, 94, 0.12);
    }

    .ai-model-badge {
        padding: 9px 13px;
        border: 1px solid rgba(56, 189, 248, 0.28);
        border-radius: 999px;
        color: #bae6fd;
        background: rgba(14, 165, 233, 0.12);
        font-size: 0.82rem;
        font-weight: 800;
    }

    .ai-form {
        margin-top: 28px;
    }

    .ai-label {
        display: block;
        margin-bottom: 10px;
        color: #f8fafc;
        font-weight: 800;
    }

    .ai-input-shell {
        position: relative;
        border: 1px solid var(--ai-card-border);
        border-radius: 24px;
        background: rgba(2, 6, 23, 0.46);
        overflow: hidden;
    }

    .ai-input-shell:focus-within {
        border-color: rgba(56, 189, 248, 0.7);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.1);
    }

    .ai-textarea {
        width: 100%;
        min-height: 230px;
        resize: vertical;
        border: 0;
        outline: 0;
        padding: 22px;
        color: var(--ai-text);
        background: transparent;
        font-size: 1rem;
        line-height: 1.65;
    }

    .ai-textarea::placeholder {
        color: #64748b;
    }

    .ai-actions {
        margin-top: 18px;
    }

    .ai-hint {
        max-width: 560px;
        color: var(--ai-muted);
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .ai-submit-button,
    .ai-copy-button {
        border: 0;
        border-radius: 16px;
        font-weight: 900;
        cursor: pointer;
        transition: transform 140ms ease, box-shadow 140ms ease, opacity 140ms ease;
    }

    .ai-submit-button {
        position: relative;
        min-width: 132px;
        padding: 14px 22px;
        color: #020617;
        background: linear-gradient(135deg, #e0f2fe, #38bdf8 55%, #0284c7);
        box-shadow: 0 18px 40px rgba(56, 189, 248, 0.28);
    }

    .ai-submit-button:hover,
    .ai-copy-button:hover {
        transform: translateY(-1px);
    }

    .ai-submit-button:disabled {
        cursor: not-allowed;
        opacity: 0.72;
        transform: none;
    }

    .ai-button-loader {
        display: none;
        width: 14px;
        height: 14px;
        margin-left: 8px;
        border: 2px solid rgba(2, 6, 23, 0.3);
        border-top-color: #020617;
        border-radius: 999px;
        vertical-align: -2px;
        animation: ai-spin 0.8s linear infinite;
    }

    .ai-submit-button.is-loading .ai-button-loader {
        display: inline-block;
    }

    .ai-alert,
    .ai-answer-card {
        margin-top: 24px;
        border: 1px solid var(--ai-card-border);
        border-radius: 22px;
        background: var(--ai-surface-strong);
    }

    .ai-alert {
        display: flex;
        gap: 14px;
        padding: 18px;
    }

    .ai-alert-error {
        border-color: rgba(251, 113, 133, 0.35);
        background: rgba(127, 29, 29, 0.22);
    }

    .ai-alert-icon {
        display: grid;
        place-items: center;
        width: 34px;
        height: 34px;
        flex: 0 0 34px;
        border-radius: 999px;
        color: #fff1f2;
        background: rgba(251, 113, 133, 0.35);
        font-weight: 900;
    }

    .ai-alert p {
        margin-top: 4px;
        color: #fecdd3;
    }

    .ai-answer-card {
        padding: 24px;
    }

    .ai-copy-button {
        padding: 10px 14px;
        color: #e0f2fe;
        background: rgba(56, 189, 248, 0.14);
        border: 1px solid rgba(56, 189, 248, 0.25);
    }

    .ai-answer {
        margin: 20px 0 0;
        padding: 22px;
        max-height: 520px;
        overflow: auto;
        white-space: pre-wrap;
        color: #dbeafe;
        background: rgba(2, 6, 23, 0.56);
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 18px;
        font-family: Consolas, Monaco, "Courier New", monospace;
        font-size: 0.96rem;
        line-height: 1.7;
    }

    @@keyframes ai-spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 980px) {
        .ai-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .ai-page-shell {
            padding: 20px 12px;
        }

        .ai-hero-card,
        .ai-chat-panel {
            padding: 22px;
            border-radius: 22px;
        }

        .ai-panel-header,
        .ai-answer-header,
        .ai-actions {
            align-items: flex-start;
            flex-direction: column;
        }

        .ai-submit-button {
            width: 100%;
        }
    }
</style>
