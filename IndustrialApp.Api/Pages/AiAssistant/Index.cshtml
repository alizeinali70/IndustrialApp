@page
@model IndustrialApp.Api.Pages.AiAssistant.IndexModel

@{
ViewData["Title"] = "Industrial AI Assistant";
}
<link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

<section class="ai-page-shell">
    <div class="ai-background-glow ai-background-glow-one"></div>
    <div class="ai-background-glow ai-background-glow-two"></div>

    <div class="ai-layout">
        <aside class="ai-hero-card">
            <div class="ai-brand-row">
                <div>
                    <div class="ai-eyebrow">Industrial Intelligence</div>
                    <h1>AI Assistant</h1>
                </div>
            </div>

            <p class="ai-hero-text">
                Ask production, quality, document, process, and log-related questions in one focused workspace.
            </p>

            <div class="ai-feature-grid">
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">◆</span>
                    <strong>Production Support</strong>
                    <span>Analyze shopfloor and process questions.</span>
                </div>
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">●</span>
                    <strong>Document Insight</strong>
                    <span>Summarize instructions and technical context.</span>
                </div>
                <div class="ai-feature-card">
                    <span class="ai-feature-icon">▲</span>
                    <strong>Quality Focus</strong>
                    <span>Reason about defects, logs, and findings.</span>
                </div>
            </div>
        </aside>

        <main class="ai-chat-panel">
            <div class="ai-panel-header">
                <div>
                    <div class="ai-status-row">
                        <span id="ollamaStatusDot" class="ai-status-dot @(Model.OllamaAvailable ? "" : "is-offline")" aria-label="@(Model.OllamaAvailable ? "Ollama is running" : "Ollama is not running")"></span>
                        <span id="ollamaStatusText">@(Model.OllamaAvailable ? "Local AI ready" : "Ollama is offline")</span>
                    </div>
                    <h2>Ask a question</h2>
                </div>
                <div class="ai-model-badge">@Model.ModelId</div>
            </div>

            <form method="post" asp-page="/AiAssistant/Index" id="aiForm" class="ai-form">
                @Html.AntiForgeryToken()

                <label asp-for="Input.Question" class="ai-label"></label>

                <div class="ai-input-shell">
                    <textarea asp-for="Input.Question"
                              class="ai-textarea"
                              rows="8"
                              placeholder="Ask something about production, documents, logs, quality issues..."></textarea>
                </div>

                <span asp-validation-for="Input.Question" class="ai-hint"></span>

                <div class="ai-actions">
                    <div class="ai-hint">
                        Tip: include part numbers, machine names, log excerpts, or document references for better answers.
                    </div>
                    <button type="submit" class="ai-submit-button" id="askButton">
                        <span class="ai-button-text">Ask AI</span>
                        <span class="ai-button-loader" aria-hidden="true"></span>
                    </button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
            <div class="ai-alert ai-alert-error" role="alert">
                <div class="ai-alert-icon">!</div>
                <div>
                    <strong>Request failed</strong>
                    <p>@Model.ErrorMessage</p>
                </div>
            </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Answer))
            {
            <section class="ai-answer-card">
                <div class="ai-answer-header">
                    <div>
                        <span class="ai-answer-kicker">AI response</span>
                        <h3>Answer</h3>
                    </div>
                    <button type="button" class="ai-copy-button" id="copyAnswerButton">Copy</button>
                </div>

                <pre class="ai-answer" id="aiAnswer">@Model.Answer</pre>
            </section>
            }
        </main>
    </div>
</section>

<script>
    const form = document.getElementById("aiForm");
    const button = document.getElementById("askButton");
    const copyButton = document.getElementById("copyAnswerButton");
    const answer = document.getElementById("aiAnswer");
    const statusDot = document.getElementById("ollamaStatusDot");
    const statusText = document.getElementById("ollamaStatusText");

    const setOllamaStatus = (isAvailable, text, ariaLabel) => {
        if (!statusDot || !statusText) {
            return;
        }

        statusDot.classList.toggle("is-offline", !isAvailable);
        statusDot.setAttribute("aria-label", ariaLabel);
        statusText.innerText = text;
    };

    const refreshOllamaStatus = async () => {
        try {
            const response = await fetch("@Url.Page("/AiAssistant/Index", pageHandler: "Status")", {
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            });

            if (!response.ok) {
                throw new Error("Status request failed.");
            }

            const data = await response.json();
            setOllamaStatus(data.ollamaAvailable, data.statusText, data.ariaLabel);
        } catch {
            setOllamaStatus(false, "Ollama is offline", "Ollama is not running");
        }
    };

    if (form && button) {
        form.addEventListener("submit", () => {
            button.disabled = true;
            button.classList.add("is-loading");
            button.querySelector(".ai-button-text").innerText = "Thinking...";
        });
    }

    if (copyButton && answer) {
        copyButton.addEventListener("click", async () => {
            await navigator.clipboard.writeText(answer.innerText);
            copyButton.innerText = "Copied";
            setTimeout(() => copyButton.innerText = "Copy", 1600);
        });
    }

    if (statusDot && statusText) {
        refreshOllamaStatus();
        setInterval(refreshOllamaStatus, 5000);
    }
</script>
